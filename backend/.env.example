# ClubResolve Backend Configuration

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/clubresolve.db

# JWT Auth
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Encryption key for BYOK API keys (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
CLUBRESOLVE_ENCRYPTION_KEY=change-me-generate-with-fernet

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma_db

# File uploads
UPLOAD_DIR=./data/uploads

# CORS (frontend URL)
CORS_ORIGINS=["http://localhost:3000"]
